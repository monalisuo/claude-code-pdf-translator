# Copy to <pdf-workdir>/.env and fill in values. Do not commit real secrets.
MINERU_API_TOKEN=your_mineru_token
PDF_TRANSLATE_LLM_BASE_URL=https://your-openai-compatible-provider.example
PDF_TRANSLATE_LLM_API_KEY=your_llm_api_key
PDF_TRANSLATE_MODEL=gpt-4o-mini
# Optional if browser auto-detection fails:
# PDF_TRANSLATE_BROWSER=/absolute/path/to/chrome-or-edge
